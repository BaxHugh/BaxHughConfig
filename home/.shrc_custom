# DEV STUFF
# ====================================================

function docker-top-container() {
	# Return the CONTAINER ID of the top-most container 
	docker container ls | grep -o -E '^[0-9,a-z]+' | head -1
}

function docker-configure-shell() {
	CONTAINER=$1
	USER=$2
	if [ -z $USER ]; then
		CONTAINER_HOME=/root
	else
		CONTAINER_HOME=/home/$USER
	fi

	FILES=("HOME/.shrc_custom" "HOME/.zshrc_config" "HOME/.bashrc_config" "HOME/.nanorc" "HOME/.inputrc" "HOME/.zsh_history")
	for file in ${FILES[@]}; do
		HOST_FILE=$(echo $file | sed "s#HOME#$HOME#")
		CONTAINERS_FILE_PATH=$(echo $file | sed "s#HOME#$CONTAINER_HOME#")
		CONTAINER_FILE=$CONTAINER:$CONTAINERS_FILE_PATH
		# echo docker cp $HOST_FILE $CONTAINER_FILE
		docker cp $HOST_FILE $CONTAINER_FILE > /dev/null
		# Change ownership to the docker's user
		if [ ! -z $USER ]; then
			docker exec --user root $CONTAINER sh -c "chown $USER:$USER $CONTAINERS_FILE_PATH"
		fi
	done
}

function poetry-remove-current-env() {
	poetry env\ remove $(poetry env\ list | head -n1 | awk '{print $1;}')
}

function rust-sandbox() {
	local ARG="${1:-new}"

	if [[ $ARG == "new" ]] then
		local SANDBOX_DIR=/tmp/rust-sandbox-$(uuidgen | cut -c 1-8)
		cargo new --quiet --vcs=none $SANDBOX_DIR && \
			code --new-window $SANDBOX_DIR && \
			code --reuse-window $SANDBOX_DIR/src/main.rs

	elif [[ $ARG == "clear" ]] then
		echo Removing directories:
		ls -A1 /tmp/ | grep -i 'rust-sandbox-' --color=never
		rm -rf /tmp/rust-sandbox-*

	elif [[ $ARG == "help" || $ARG == "--help" ]] then
		echo "Usage: $funcstack[1] [new | clear ]"
		echo "Default is new"
	fi
}

# uv managed virtual envs helpers
##################################


activate() {
	ENV_NAME=$1
	ENVS_DIR="$HOME/.myenvs"

	if [ -z "$ENV_NAME" ]; then
		echo "Usage: activate <env_name>"
		return 1
	fi

	if [ -d "$ENVS_DIR/$ENV_NAME" ]; then
	    # in a new zsh shell so we can deactivate exit with ctrl-d
		zsh --rcs -c "source $ENVS_DIR/$ENV_NAME/bin/activate; exec zsh"
	else
		echo "Environment '$ENV_NAME' does not exist in $ENVS_DIR" > /dev/stderr
		return 1
	fi
}

create-env() {
	ENV_NAME=$1
	ENVS_DIR="$HOME/.myenvs"

	if [ -z "$ENV_NAME" ]; then
		echo "Usage: create-env <env_name>"
		return 1
	fi

	if [ -d "$ENVS_DIR/$ENV_NAME" ]; then
		echo "Environment '$ENV_NAME' already exists in $ENVS_DIR" > /dev/stderr
		return 1
	else
		uv venv "$ENVS_DIR/$ENV_NAME"
		if [ $? -ne 0 ]; then
			echo "Failed to create virtual environment." > /dev/stderr
			return 1
		fi
		# install some useful packages
		uv pip install --python $ENVS_DIR/$ENV_NAME/bin/python pip ipython ruff mypy
	fi
}

delete-env() {
	ENV_NAME=$1
	ENVS_DIR="$HOME/.myenvs"

	if [ -z "$ENV_NAME" ]; then
		echo "Usage: delete-env <env_name>"
		return 1
	fi

	if [ -d "$ENVS_DIR/$ENV_NAME" ]; then
		rm -rf "$ENVS_DIR/$ENV_NAME"
		if [ $? -ne 0 ]; then
			echo "Failed to delete environment '$ENV_NAME'." > /dev/stderr
			return 1
		fi
	else
		echo "Environment '$ENV_NAME' does not exist in $ENVS_DIR" > /dev/stderr
		return 1
	fi
}


